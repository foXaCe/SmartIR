{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "forkProcessing": "enabled",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(deps)",
    "group:allNonMajor",
    ":dependencyDashboard",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":maintainLockFilesWeekly",
    ":timezone(Europe/Paris)"
  ],
  "baseBranches": ["main"],
  "labels": ["dependencies"],
  "reviewers": ["foXaCe"],
  "assignees": ["foXaCe"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "rangeStrategy": "auto",
  "rebaseWhen": "auto",
  "minimumReleaseAge": "3 days",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "📦 Renovate Dependency Dashboard",
  "configMigration": true,
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "minimumReleaseAge": null,
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true,
      "labels": ["dependencies", "auto-merge"]
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major", "needs-review"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["pip_requirements", "pep621"],
      "labels": ["dependencies", "python"]
    },
    {
      "matchManagers": ["github-actions"],
      "labels": ["dependencies", "github-actions"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["pre-commit"],
      "labels": ["dependencies", "pre-commit"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchPackageNames": ["ruff", "mypy"],
      "groupName": "lint & format tools",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchPackageNames": ["/^pytest/"],
      "groupName": "pytest stack"
    }
  ],
  "pre-commit": {
    "enabled": true
  },
  "ignorePaths": [
    "**/node_modules/**",
    "**/.venv/**",
    "**/venv/**",
    "**/__pycache__/**"
  ]
}
